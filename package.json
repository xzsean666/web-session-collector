{
  "name": "web-session-collector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "collect": "tsx src/scripts/collect.ts",
    "collect:xiaohongshu": "tsx src/scripts/collect.ts --site=xiaohongshu",
    "search": "tsx src/scripts/collect.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "pnpm run build && node --test dist/tests/*.test.js"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "playwright": "^1.60.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
