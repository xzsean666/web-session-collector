# ===================== 采集脚本配置(collect-loop.sh)=====================
#
# 用法:
#   cp examples/.env.example examples/.env
#   # 编辑 examples/.env 填入下面的值
#   ./examples/collect-loop.sh          # 会自动加载同目录的 .env
#
# 说明:命令行传入的关键词参数优先级高于这里的 KEYWORDS。
# 留空的项会使用脚本/服务端的默认值。
# =========================================================================

# 时区:让日志/Slack/采集时间戳显示为服务器所在地的时间。
# 按服务器实际位置填,例如日本=Asia/Tokyo,中国=Asia/Shanghai,美东=America/New_York。
TZ=Asia/Tokyo

# API 地址(小红书采集服务)
BASE_URL=http://100.90.168.1:10085

# idle noVNC 远程桌面地址 —— 账号掉登录时通知里会带上,方便你人工登录/过验证码
IDLE_NOVNC_URL=http://100.90.168.1:10087/vnc.html

# Slack Incoming Webhook 地址;留空则不发通知
# 获取方式:Slack 后台 → 创建/选择 App → 启用 Incoming Webhooks → 复制 URL
SLACK_WEBHOOK_URL=

# 是否把每一条【新】笔记单独发一条 Slack(方便实时看最新内容):1=开,0=关
SLACK_EACH=1
# 每轮逐条发送的上限(防刷屏);超出的不再逐条发,但仍会写入数据文件
SLACK_EACH_MAX=50
# 逐条发送之间的间隔秒数(避免触发 Slack 限流;消息多时建议 ≥1)
SLACK_EACH_DELAY=1
# 逐条新笔记通知是否附带 session/failover 提示;默认 0,避免成功采集时误报需要登录
SLACK_EACH_SESSION_NOTICE=0

# 关键词:用【逗号】分隔。单个关键词内部可以含空格做联合搜索。
# ⚠️ 因为是 .env 文件,只要值里有空格就【必须用引号包起来】,否则 source 会报错。
#   例:        KEYWORDS="美食,旅行,穿搭"
#   联合搜索例:KEYWORDS="美食 火锅,成都 旅游,秋冬 穿搭"
KEYWORDS="美食,旅行,穿搭"

# 采集数据目录(留空 = <仓库>/data)。数据写入 notes.jsonl,去重表 seen_ids.txt
DATA_DIR=

# 每轮采集之间的间隔秒数(默认 1800 = 30 分钟)
INTERVAL=1800

# 只跑一轮就退出(测试用):填 1 启用;留空 = 持续循环
ONCE=

# ---- 搜索参数覆盖(留空 = 用服务端默认值 recentDays=90 / limit=30 / scroll=5)----
# 只保留最近 N 天的笔记(0 = 不按时间过滤)
RECENT_DAYS=
# 每个关键词最多返回条数
LIMIT=
# 结果页向下滚动加载次数(上限);有了"够了/滚过时间窗口就停"的早停,调高也安全、不浪费
SCROLL_COUNT=8

# 是否额外打开每条笔记详情页抓取【正文/标签/图片】:1=开,0=关
# 注意:开启后每条多一次页面加载,明显变慢,也更容易触发验证码。
FETCH_CONTENT=0

# 每次请求只把【最近收集的 N 个 id】传给 API(excludeItemIds),让它跳过这些笔记的详情页。
# 传太多没必要:搜索返回的都是较新笔记,漏掉的重复项本地去重还能兜底。0=不限制(不建议)。
EXCLUDE_MAX=500

# ---- 遇到“任务忙(409)”时的重试策略 ----
BUSY_RETRIES=10
BUSY_WAIT=15

# active session 失效时自动切换到 state=logged_in 且空闲的备用 session:1=开,0=关
FAILOVER=1

# failover 前先重启当前 active session 浏览器尝试恢复:1=开,0=关
SESSION_RESTART=1
# 重启后等待几秒再检查登录态
SESSION_RESTART_WAIT=5
# 每次恢复最多重启几次;仍不可用才切备用 session / 发 Slack 报告
SESSION_RECOVERY_RETRIES=1
